FoamFile {
  version     2.0;
  format      ascii;
  class       dictionary;
  object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     PATOx;

startFrom       startTime       0;

startTime       0;

stopAt          endTime;

endTime         0.25;

deltaT          0.001;

writeControl    adjustableRunTime;

writeInterval   0.25;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression uncompressed;

timeFormat      general;

timePrecision   7;

graphFormat     xmgr;

runTimeModifiable yes;

adjustTimeStep  no; // you can turn it off but its going to be very slow

maxCo           10;

maxDeltaT   0.001; // reduce it if the surface temperature starts oscilliating

minDeltaT   1e-6;

REVlength   1e3;
// ************************************************************************* //
