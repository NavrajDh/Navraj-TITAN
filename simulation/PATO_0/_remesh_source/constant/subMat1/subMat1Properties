FoamFile {
  version     4.0;
  format      ascii;
  class       dictionary;
  location    "constant/subMat1";
  object      subMat1Properties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

/****************************** GENERAL ************************************/
//debug yes;
movingMesh      no;
/****************************** end GENERAL ********************************/

/****************************** IO *****************************************/
IO {
  writeFields(); // write fields in the time folders
}
/****************************** END IO ************************************/

/****************************** MASS **************************************/
Mass {
  createFields ((p volScalarField)); // read pressure [Pa]
}
/****************************** END MASS **********************************/

/****************************** ENERGY ************************************/
Energy {
  EnergyType PureConduction; // Solve the temperature equation
}
/****************************** END ENERGY ********************************/

/****************************** MATERIAL PROPERTIES  ************************/
MaterialProperties {
  MaterialPropertiesType Fourier; 
  MaterialPropertiesDirectory "$FOAM_CASE/data"; 
}
/****************************** END MATERIAL PROPERTIES  ********************/
